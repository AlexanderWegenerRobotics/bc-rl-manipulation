<mujoco model="pick_place_scene">

  <compiler angle="radian" meshdir="franka_fr3/assets" autolimits="true"/>
  <option integrator="implicitfast" timestep="0.001"/>
  <statistic center="0.4 0.0 0.5" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global offwidth="1280" offheight="960" azimuth="140" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="target_mat" rgba="0.1 0.8 0.1 0.4"/>
  </asset>

  <include file="franka_fr3/fr3_with_hand.xml"/>
  <include file="props/table.xml"/>
  <include file="props/box.xml"/>

  <worldbody>
    <light pos="0 0 2.0" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="place_target" pos="0.6 0.0 0.62" mocap="true">
      <geom type="box"     size="0.025 0.025 0.001" material="target_mat" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0 0 0 0.04 0 0"  size="0.003" rgba="1 0 0 0.6" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0 0 0 0 0.04 0"  size="0.003" rgba="0 1 0 0.6" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0 0 0 0 0 0.04"  size="0.003" rgba="0 0 1 0.6" contype="0" conaffinity="0"/>
    </body>
  </worldbody>

  <keyframe>
    <key name="home" qpos="-0.3 -1.1 0.3 -2.0 0.5 2.9 -0.9 0.04 0.04" ctrl="0 0 0 0 0 0 0 255"/>
  </keyframe>

</mujoco>